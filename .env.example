# =============================================================================
# AutoAgentHire Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=AutoAgentHire
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL (Supabase Transaction Pooler — use this format for Supabase)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
SYNC_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# SQLite (Development fallback)
# DATABASE_URL=sqlite:///./data/autoagenthire.db

# -----------------------------------------------------------------------------
# Vector Search Configuration (ALL OPTIONAL — graceful degradation)
# -------------------------------------------------------
# EMBEDDING FALLBACK CHAIN (tries each in order):
# 1. Local model (sentence-transformers) - if installed, fastest
# 2. OpenAI API (text-embedding-3-small) - RECOMMENDED, quality embeddings
# 3. Gemini API (text-embedding-004) - good quality, balanced cost
# 4. Groq API (nomic-embed-text-v1.5) - works but may be slower
# 5. Hash-based (emergency fallback, poor quality)
#
# Option 1: Qdrant Cloud (OPTIONAL — for production semantic search)
#   Leave empty to disable. If set, requires BOTH to be configured.
QDRANT_URL=
QDRANT_API_KEY=

# Option 2: API-based embeddings (set at least ONE for smart job matching)
#   Priority: OpenAI > Gemini > Groq
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# AI/LLM API Keys
# -----------------------------------------------------------------------------
# OpenAI (optional — free tier available via GitHub Models)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# GitHub Models (primary — free, requires GitHub PAT with models scope)
GITHUB_API_KEY=github_pat_your_token_here

# Groq (fast + free fallback — recommended)
GROQ_API_KEY=gsk_your_groq_key_here

# Google Gemini (alternative)
GEMINI_API_KEY=your-gemini-api-key

# Anthropic Claude (Optional)
# ANTHROPIC_API_KEY=your-anthropic-key

# Local LLM (Optional)
# LLAMA_MODEL_PATH=/path/to/llama/model

# -----------------------------------------------------------------------------
# CrewAI
# -----------------------------------------------------------------------------
CREWAI_TELEMETRY=false

# -----------------------------------------------------------------------------
# OAuth Configuration
# -----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# LinkedIn OAuth
LINKEDIN_OAUTH_CLIENT_ID=your-linkedin-client-id
LINKEDIN_OAUTH_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# -----------------------------------------------------------------------------
# LinkedIn Automation Credentials
# -----------------------------------------------------------------------------
# WARNING: Use with caution! LinkedIn may flag automated activity
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# -----------------------------------------------------------------------------
# User Profile (for form auto-fill during job applications)
# -----------------------------------------------------------------------------
FIRST_NAME=
LAST_NAME=
PHONE_NUMBER=
CITY=
LINKEDIN_URL=https://linkedin.com/in/yourprofile
PORTFOLIO_URL=
YEARS_EXPERIENCE=3
# 0 = immediately available; set to number of days notice required
NOTICE_PERIOD_DAYS=0
EXPECTED_SALARY=
# Current CTC (cost to company) – numeric, e.g. 500000
CURRENT_CTC=0
DRIVERS_LICENSE=Yes
GENDER=Male
# CGPA/GPA for internship applications
CGPA=8.0
INTERNSHIP_MONTHS=6
# Comma-separated skill:years pairs e.g. Python:4,FastAPI:3,SQL:5
SKILL_EXPERIENCE=

# -----------------------------------------------------------------------------
# Web Automation Settings
# -----------------------------------------------------------------------------
SELENIUM_HEADLESS=true
SELENIUM_IMPLICIT_WAIT=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Proxy Configuration (Optional)
# -----------------------------------------------------------------------------
USE_PROXY=false
# PROXY_URL=http://proxy-server:port

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
NOTIFICATION_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# Celery (Background Tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# -----------------------------------------------------------------------------
# Job Search Settings
# -----------------------------------------------------------------------------
MAX_JOBS_PER_SEARCH=100
SEARCH_DELAY_SECONDS=2
MAX_APPLICATIONS_PER_DAY=10

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AUTO_APPLY=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_DAILY_REPORTS=true

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# SENTRY_DSN=your-sentry-dsn
ENABLE_METRICS=true
METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-encryption-key

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
STREAMLIT_PORT=8501
REACT_APP_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8501

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
ALLOWED_RESUME_EXTENSIONS=pdf,docx,txt

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_FILE_PATH=data/logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# -----------------------------------------------------------------------------
# Supabase Project Keys (optional — for Supabase SDK features)
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_KEY=your-supabase-anon-key

# =============================================================================
# Production Notes
# =============================================================================
# For production deployment:
# 1. Set APP_ENV=production
# 2. Set DEBUG=false  
# 3. Use strong SECRET_KEY and ENCRYPTION_KEY
# 4. Use PostgreSQL instead of SQLite
# 5. Configure proper CORS_ORIGINS for your frontend domain
# 6. Set SELENIUM_HEADLESS=true and PLAYWRIGHT_HEADLESS=true
# 7. Configure Sentry for error tracking
# 8. Use environment-specific API keys
# 9. Enable rate limiting appropriately
# 10. Set up proper database backups