# .dockerignore — exclude files from Docker build context
# Keeps image small and prevents secrets leaking into the image

# ── Secrets & environment ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.virtualenv/

# ── Data & uploads (mounted as volume at runtime) ─────────────────────────────
data/
uploads/
vector_db/
browser_profile/

# ── Frontend (not needed in backend image) ────────────────────────────────────
frontend/
scripts/
docs/

# ── Git & IDE ─────────────────────────────────────────────────────────────────
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
*.swo

# ── Docker files (not needed inside container) ─────────────────────────────────
docker/
docker-compose*.yml

# ── Test & dev files ───────────────────────────────────────────────────────────
tests/
test_*.py
*_test.py
pytest.ini
.coverage
htmlcov/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Large binary/cache files ──────────────────────────────────────────────────
*.pkl
*.faiss
*.bin
node_modules/
